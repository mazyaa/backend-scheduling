{
  "name": "backend-scheduling",
  "version": "1.0.0",
  "description": "backend for web app scheduling and e-certificate issuance",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "postinstall": "prisma generate",
    "build": "tsc && prisma generate",
    "start": "tsc && prisma migrate deploy && ts-node src/utils/prisma/seed.ts && node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:init": "prisma migrate dev --name init",
    "db:migrate": "prisma migrate dev",
    "db:migrate-fresh": "prisma migrate reset",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "db:seed": "ts-node src/utils/prisma/seed.ts"
  },
  "prisma": {
    "schema": "src/utils/prisma/schema.prisma"
  },
  "author": "mazyaa",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "archiver": "^8.0.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "ejs": "^6.0.1",
    "eslint": "^9.39.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemon": "^3.1.11",
    "pg": "^8.16.3",
    "prettier": "^3.7.4",
    "puppeteer": "^25.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^5.4.7",
    "prisma": "^7.8.0"
  }
}
