<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bree+Serif&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        width: 1123px;
        height: 794px;
        overflow: hidden;
        font-family: 'Times New Roman', Times, serif;
      }

      .certificate {
        position: relative;
        width: 1123px;
        height: 794px;
      }

      /* Background */

      .background {
        position: absolute;
        inset: 0;

        width: 100%;
        height: 100%;

        object-fit: cover;
        z-index: 1;
      }

      /* Content Layer */

      .content {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 100%;
      }

      h1 {
        font-family: 'Bree Serif', serif;
        position: absolute;

        top: 110px;
        left: 70px;

        font-size: 80px;
        font-weight: 500;
      }

      /* Nomor Sertifikat */

      .certificate-number {
        font-family: "Open Sans", sans-serif;
        position: absolute;

        top: 205px;
        left: 70px;

        font-size: 20px;
        font-weight: 650;
      }

      /* Nama Peserta */

      p {
        font-family: 'Times New Roman', Times, serif;
        position: absolute;

        top: 300px;
        left: 70px; 

        font-size: 23px;
      }

      .participant-name {
        font-family: 'Bree Serif', serif;
        position: absolute;

        top: 350px;
        left: 70px;

        width: 820px;

        text-align: left;

        font-size: 43px;
        font-weight: 500;

        text-transform: uppercase;
        word-wrap: break-word;
      }

      /* Deskripsi */

      .description {
        font-family: 'Times New Roman', Times, serif;
        position: absolute;

        top: 430px;
        left: 70px;

        width: 780px;

        font-size: 20px;
        line-height: 1.5;
      }

      .description strong {
        font-family: 'Times New Roman', Times, serif;
        font-weight: 700;
      }

      /* Tanggal */

      .date {
        position: absolute;

        left: 70px;
        bottom: 213px;

        font-size: 18px;
      }

      /* Perusahaan */

      .company {
        position: absolute;

        left: 70px;
        bottom: 185px;

        font-size: 18px;
        font-weight: 700;
      }

      /* Direktur */

      .director {
        position: absolute;

        left: 70px;
        bottom: 40px;
      }

      .director-name {
        font-family: "Montserrat", sans-serif;
        font-size: 20px;
        font-weight: 700;
      }

      .director-position {
        font-size: 18px;
      }
    </style>
  </head>

  <body>
    <div class="certificate">
      <img
        src="<%= backgroundImage %>"
        alt="Certificate Background"
        class="background"
      />

      <div class="content">
        <h1>SERTIFIKAT</h1>
        <div class="certificate-number">No. <%= nomorSertifikat %></div>
        <p>Diberikan Kepada :</p>
        <div class="participant-name"><%= namaPeserta %></div>

        <div class="description">
          Sebagai peserta
          <strong>Training Awareness</strong>
          <strong><%= namaMateri %></strong>
          <br />
          Pada tanggal <%= tanggalTraining %> via Zoom Meeting yang
          diselenggarakan
          <br />
          oleh
          <strong>PT Veritrust Global Solusindo</strong>
        </div>

        <div class="date">Serang, <%= tanggalTerbit %></div>

        <div class="company">PT Veritrust Global Solusindo</div>

        <div class="director">
          <div class="director-name">Abdul Darda, S.H., M.H.</div>

          <div class="director-position">Direktur Utama</div>
        </div>
      </div>
    </div>
  </body>
</html>
