<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    width: 1123px;
    height: 794px;
    overflow: hidden;
    font-family: "Times New Roman", serif;
}

.certificate {
    position: relative;
    width: 1123px;
    height: 794px;
}

/* Background */

.background {
    position: absolute;
    inset: 0;

    width: 100%;
    height: 100%;

    object-fit: cover;
    z-index: 1;
}

/* Content Layer */

.content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
}

/* Nomor Sertifikat */

.certificate-number {
    position: absolute;

    top: 185px;
    left: 60px;

    font-size: 20px;
    font-weight: 700;
}

/* Nama Peserta */

.participant-name {
    position: absolute;

    top: 300px;
    left: 80px;

    width: 820px;

    text-align: left;

    font-size: 34px;
    font-weight: 700;

    text-transform: uppercase;
    word-wrap: break-word;
}

/* Deskripsi */

.description {
    position: absolute;

    top: 370px;
    left: 60px;

    width: 780px;

    font-size: 18px;
    line-height: 1.5;
}

.description strong {
    font-weight: 700;
}

/* Tanggal */

.date {
    position: absolute;

    left: 60px;
    bottom: 170px;

    font-size: 18px;
}

/* Perusahaan */

.company {
    position: absolute;

    left: 60px;
    bottom: 135px;

    font-size: 18px;
    font-weight: 700;
}

/* Direktur */

.director {
    position: absolute;

    left: 60px;
    bottom: 40px;
}

.director-name {
    font-size: 18px;
    font-weight: 700;
}

.director-position {
    font-size: 18px;
}

</style>
</head>

<body>

<div class="certificate">

    <img
        src="<%= backgroundImage %>"
        alt="Certificate Background"
        class="background"
    />

    <div class="content">

        <div class="certificate-number">
            No. <%= nomorSertifikat %>
        </div>

        <div class="participant-name">
            <%= namaPeserta %>
        </div>

        <div class="description">
            Sebagai peserta
            <strong><%= namaTraining %></strong>
            (Batch <%= batch %>)
            <br><br>

            Telah menyelesaikan materi kompetensi:
            <strong><%= namaMateri %></strong>
            <br><br>

            Pada tanggal
            <%= tanggalTraining %>

            yang diselenggarakan oleh
            <strong>PT Veritrust Global Solusindo</strong>
        </div>

        <div class="date">
            Serang, <%= tanggalTerbit %>
        </div>

        <div class="company">
            PT Veritrust Global Solusindo
        </div>

        <div class="director">
            <div class="director-name">
                Abdul Darda, S.H., M.H.
            </div>

            <div class="director-position">
                Direktur Utama
            </div>
        </div>

    </div>

</div>

</body>
</html>